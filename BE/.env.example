# Server
NODE_ENV=production
PORT=8080

# Database
DB_HOST=localhost
DB_PORT=3306
DB_USER=root
DB_PASSWORD=your_password
DB_NAME=gearbox_db

# CORS - Thêm URL Vercel của bạn
CORS_ORIGIN=http://localhost:5173,https://your-fe-name.vercel.app

# JWT
JWT_SECRET=your_secret_key
JWT_EXPIRE=7d

# Other
LOG_LEVEL=debug
